# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# LiteLLM
LITELLM_DATABASE_URL=postgresql://postgres:change-me@postgres:5432/litellm
LITELLM_MASTER_KEY=sk-your-master-key

# LLM Providers (add only the ones you use)
GEMINI_API_KEY=your-gemini-key-here
OPENAI_API_KEY=your-openai-key-here
OPENROUTER_API_KEY=your-openrouter-key-here

# Langfuse auth (generate with: python -c "import secrets; print(secrets.token_hex(32))")
NEXTAUTH_SECRET=generate-a-random-string
LANGFUSE_SALT=generate-a-random-string
ENCRYPTION_KEY=generate-a-64-char-hex-string

# Langfuse keys (get from http://localhost:3000 after first run)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse-web:3000

# ClickHouse
CLICKHOUSE_PASSWORD=clickhouse

# Redis
REDIS_AUTH=change-me

# MinIO
MINIO_SECRET=change-me
