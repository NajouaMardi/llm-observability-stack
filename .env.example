# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Langfuse (v2) ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=generate-a-random-string
LANGFUSE_SALT=generate-a-random-string

# Langfuse API keys — get from http://localhost:3001 after first boot:
#   Create account → New Project → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Bifrost OTel auth for Langfuse — generate AFTER you have your keys above:
# Windows PowerShell:
#   $b = [Text.Encoding]::UTF8.GetBytes("pk-lf-xxx:sk-lf-xxx")
#   "Basic " + [Convert]::ToBase64String($b)
# Linux/Mac:
#   echo "Basic $(echo -n 'pk-lf-xxx:sk-lf-xxx' | base64)"
# IMPORTANT: use echo -n (no trailing newline) or the token will be invalid
LANGFUSE_AUTH=Basic your-base64-here

# ── GitHub (optional) ──────────────────────────────────────────────────────────
# Raises GitHub API rate limit from 60 to 5000 req/hour
# GITHUB_TOKEN=ghp_your-token-here

# ── Discord webhook for Bifrost alerts ────────────────────────────────────────
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-id/your-token

# ── Monitor thresholds ─────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60          # how often to check metrics
ERROR_RATE_THRESHOLD=0.1          # alert if >10% of requests error
LATENCY_THRESHOLD_MS=5000         # alert if avg latency >5s
P95_LATENCY_THRESHOLD_MS=10000    # alert if p95 latency >10s
COST_SPIKE_THRESHOLD=1.0          # alert if >$1 spent in 5 min window
TOTAL_COST_DAILY_THRESHOLD=10.0   # alert if >$10 spent today
FALLBACK_RATE_THRESHOLD=0.2       # alert if >20% of requests fall back
MIN_REQUESTS_FOR_ALERT=5          # ignore windows with fewer requests than this
BUDGET_ALERT_THRESHOLD=0.8        # alert at 80% of virtual key budget used
CACHE_HIT_RATE_THRESHOLD=0.3      # alert if cache hit rate drops below 30%
